# Supabase Postgres connection string (Transaction pooler, port 6543).
# Get it from: Supabase dashboard -> Project Settings -> Database -> Connection string -> "Transaction" (URI).
# Replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL=postgresql://postgres.jxlrnuyfracyygiksqdj:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Password to access the private dashboard.
DASHBOARD_PASSWORD=change-me

# Google OAuth (Connect Google on /onboard: GA4 now, Google Ads once dev token approved).
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client (Web application).
# The client SECRET goes in Supabase secrets (GOOGLE_OAUTH_CLIENT_SECRET), not here.
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Google Search Console ownership token (OAuth branding verification).
# Search Console -> add URL-prefix property -> HTML tag method -> copy the content="..." value.
GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxx

# Dropbox (composer "Add from Dropbox"). Create an app at dropbox.com/developers
# (scoped access, files.metadata.read + files.content.read). The SECRET goes in
# Supabase secrets (DROPBOX_APP_SECRET), not here.
DROPBOX_APP_KEY=xxxxxxxxxxxx
